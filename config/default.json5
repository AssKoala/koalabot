{
    // Developer/Troubleshooting Settings not meant for general production use.
    Developer: {
        debugEnable: false,                                                 // Enable debugging paths, not meant for production as these paths may not be as well tested.
        timingEnable: false,                                                // If true, enable timing markers that output call timings to TTY and logs
        Flags: {
            enableExperimentalChatSystem: false                            // If true, enables the experimental chat system that is under development.
        },
        Hacks: {
            // openAiOssApiKey: "lm-studio",                                  // API key for gpt-oss
            // openAiOssBaseUrl: "http://192.168.69.69:1234/v1"               // Base URL for gpt-oss model calls.  If provided, will route any model named gpt-oss-* to this endpoint.
            // responseTimeout: 300000                                        // Timeout in ms for waiting for responses from the LLM, increase if you are getting timeouts with larger models or during high load, decrease if you want faster failure when the LLM is not responding.
        }
    },
    // Global Settings
    Global: {
        botName: "KoalaBot",
        commandPath: "./commands",                                          // Path to commands folder allowing override. Don't mess with this if you don't know what you're doing.
        commandList: "settings,coinflip,diceroll,leaderboard,stock,market",        // Comma separate list of commands to load.  All commands are expected to be in the commandPath folder and implement the DiscordBotCommand interface.
        dataPath: "./data",                                                 // Path to general data storage
        localDataPath: "./data/local",                                      // Path where bot instance specific data can be stored, such as guild specific settings, etc.  This allows for easier separation of data if you are running multiple instances of the bot with the same data path.
        tempPath: "./temp",                                                 // Path to write temporary files
        scriptPath: "./scripts",                                            // Path to load external scripts from
        logMaxEntries: 2048,                                                // Maximum number of log entries to keep in memory, should be the same or slightly higher than GPT_MAX_MESSAGES.
        logPath: "./logs",                                                  // Folder to write logs to
        fullLogFilename: "bot.log",                                         // Log file to write ALL logs to
        messageLogFilename: "discord_messages.log",                         // Log file to write discord messages to
        logLevel: "info",                                                   // Logging level.  See logger.ts enum LogLevel for available levels.
        pythonBinary: "python",                                             // Path to python binary
        rebootFile: "./temp/reboot.txt",                                    // File used to trigger reboots when written to, should be touchable by the bot process
        sudoList: "",                                                       // Comma separated list of discord user id's that have sudo access to bot.
        versionInfoFile: "./version.json"                                   // Path to version information file
    },
    Reddit: {
        readerScriptName: "reddit_reader.py",                         // Path to reddit reader python program (relative to SCRIPTS_PATH)
        clientId: "",                                                 // Reddit app client id: https://www.reddit.com/prefs/apps
        clientSecret: "",                                             // Reddit app client secret: https://www.reddit.com/prefs/apps
        userAgent: ""                                                 // Reddit custom user agent for use in praw
    },
    ImageGeneration: {
        // Comma separate list of AI image generation models to use slash commands with (requires reloading guild commands when changing this value). 
        // Default is all available, so remove any AI services you dont have an API key for (or just dont want to use).
        availableAiImageGenerators: "stablediffusion,dall-e-3,getimg.ai-flux,gpt-image-1,grok-2-image",
        enabledAiImageGenerators: "stablediffusion,dall-e-3,getimg.ai-flux,gpt-image-1,grok-2-image",
        StableDiffusion: {
            webUiAddress: "127.0.0.1:7860",                  // host:port of stable diffusion host
            // Command separate list of displayName(on-disk-name) checkpoints for use in calls to the SD web-ui.  If an (on-disk-name) is not provided, 
            // it will be generated by appending .safetensors to the displayName. 
            // E.g. a value of "deliberate_v6" will result in attempting to use deliberate_v6.safetensors from disk
            checkpoints: "deliberate(Deliberate_v6.safetensors),dreamshaper(dreamshaper_8.safetensors)"
        },
        saveImages: true,                  // If true save images.  Image info will be stored as xml alongside.
        imageSavePath: "./generated_images" // Path to save generated images if saveImages is true.
    },
    APIKey: { // Keep these private.  Defaults are here for reference.  Optionally loads from environment variables.
        anthropic: "",
        gemini: "",         // API key requires google vertex AI access.  Attach svc account with Vertex User Permissions at least.
        getimgai: "",
        googleMaps: "",     // API Key requires google geocode API access
        grok: "",
        ollama: "",
        openai: "",
        openWeather: "",
        shortenUrl: ""
    },
    Chat: {
        aiModel: "gpt-5.1",                             // Default LLM model to use, see AiModels.availableModels below for full list
        aiModelNano: "gpt-5-nano",                     // Default LLM nano model to use for smaller responses
        AiModels: {
            // Comma separated list of available models, do not override unless you know what you are doing.
            availableModels: "gpt-4o,gpt-5-nano,gpt-5,gpt-5.1,gpt-5.2,gpt-5.5,grok-4.3,gemini-2.5-flash,gemini-3-flash-preview",
            // Remove models from the list to disable their use.  New models won't be available automatically if overriden.
            enabledModels: "gpt-4o,gpt-5-nano,gpt-5,gpt-5.1,gpt-5.2,gpt-5.5,grok-4.3,gemini-2.5-flash,gemini-3-flash-preview"
        },
        enableLongDescription: true,                    // If enabled, responses with images will include the revised prompt as the embed description
        maxMessages: 2048,                              // Max number of message history to send during chat interaction
        maxSoulTokens: 3500,                            // Max number of tokens to send from soul during chat interaction
        maxTokenCount: 16384,                           // Max number of tokens to send during chat interaction
        ImageGeneration: {
            enable: true,                               // If true, enable image generation in chat
        },
        WebSearch: {
            enable: true,                               // If true, enable web search (use as input) in chat
        },
        ImageVision: {
            enable: true,                               // If true, enable image vision (use as input) in chat
            maxImages: 5                                // Max number of images to send as input in a single request
        },
        // Common prompt to include in all messages (appended to the systemPrompt) to tell the bot how to format its responses, etc.
        commonPrompt: "When replying with text, do not include your name or discord id at the front of the response as in a chat log, just respond with the message content.",   
        // Generic prompt when you want a proper response
        genericSystemPrompt: "You are a helpful assistant.",
        // Prompt to tell the robot how to behave.  It is prepended automatically to tell the bot its own name, discord Id, and chat format, so just give it the details of how to act (e.g. you are a helpful assistant)
        systemPrompt: "You are a helpful assistant.",
        // Path to a system soul file, relative to localDataPath, overrides the systemPrompt if provided.
        systemSoul: "systemSoul.md",
        // Prompt to use to generate an image description for image gen from text completion
        imageGenDescriptionPrompt: "Generate a detailed description of an image based on the following question and chat room context that can be used as the prompt to an AI image generator to respond to the following message, without any additional fluff, snark or personality: "
    },
    AiModel: {
        Ollama: {
            serverAddress: "http://127.0.0.1:11434"     // Ollama server
        },
        Gemini: {
            imageAiModel: "gemini-3.1-flash-image-preview"  // Default gemini image model
        },
        Grok: {
            imageAiModel: "grok-2-image"               // Grok image generation model to use by default
        }
    },
    Discord: {
        token: "",                                      // Discord bot token
        appId: "",                                      // Discord app id for bot
        guildIds: "",                                   // Comma separate list of guilds the bot will join.
        clearSlashCommandsOnStartup: true,              // Clear slash commands on startup, recommend true for production use.
        deployGuildSlashCommandsOnStartup: true,        // Deploy slash commands to guilds, recommend true for production use
        deployGlobalSlashCommandsOnStartup: false,      // Deploy slash commands globally for bot, recommend to always be false
        attachmentTitleMaxLength: 256,                  // Title length for image embeds
		attachmentDescriptionMaxLength: 1024,           // Description length for image embeds
        maxTypingTimeMs: 120000                         // Max time to send typing indicator for long responses (e.g. image generation)
    },
    Listeners: {
        listenerList: "loglistener,deletebotmessagereactionlistener",       // Comma separated List of listener modules to load
        BadWordListener: {
            badwords: "",                               // Comma separated list of bad words to track
            trackingChannelIds: "",                     // Comma separated list of discord channel id's to track for bad words
            saveDir: "/badword-tracking"                // Path to save badword tracking data (appended to local data path, e.g. ./data/local/badword-tracking/badword.json)
        },
        WordTracker: {
            fileName: "wordtracker.json"                // Filename storing words to track (will load from DATA_PATH)
        },
        MessageResponder: {
            datasetFilename: "messageresponder_dataset.json",   // Filename storing message responder dataset (will load from DATA_PATH)
            aiCooldownMs: 30000                                  // Cooldown before AI will make an AI call
        }
    },
    ShortenUrl: {
        shlinkBaseAddress: ""                // Shlink host
    },
    Stenographer: {
        storeImages: false                  // If true, store images in stenographer logs
    },
    Modules: {
        Honcho: {
            enabled: true,                          // If true, enable honcho module
            Config: {
                workspaceId: "",                        // Override botname as workspace id
                apiKey: "",                             // Honcho API key
                baseUrl: "https://api.honcho.dev",      // Honcho API url
                environment: "production",              // Honcho environment to use (valid values are production or local)
                timeout: 30000,                         // Timeout in ms for honcho API calls
                maxRetries: 3                           // Max number of retries for honcho API calls
            },
            Constants: {
                // Internal: prefix to system prompt ahead of honcho info
                systemPromptPrefix: "Use the following behavioral patterns, user background, and context summary to tailor your tone and answers."
            }
        }
    }
}